# ═══════════════════════════════════════════════════════════════════════════════
# OCR — Variables de entorno
# Copiar como .env y ajustar antes de levantar los servicios.
# ═══════════════════════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────────────────────
# MUNIS — Integración con el sistema de Normatividad
# ───────────────────────────────────────────────────────────────────────────────

# URL base de la instancia Munis (sin barra final).
# El worker hará peticiones a: ${MUNIS_BASE_URL}/api/ocr/normatividad/queue/...
MUNIS_BASE_URL=http://gp_webserver

# Bearer token para autenticar las peticiones del worker contra Munis.
# Debe coincidir con el token configurado en Munis para este servicio OCR.
MUNIS_OCR_TOKEN=CAMBIAR_POR_TOKEN_REAL


# ───────────────────────────────────────────────────────────────────────────────
# OCR WORKER — Comportamiento del consumidor de cola
# ───────────────────────────────────────────────────────────────────────────────

# Nombre descriptivo del worker (aparece en logs y en el payload de "complete").
OCR_WORKER_NAME=ocr-worker-1

# Cantidad de consumidores paralelos dentro del mismo servicio/contendor.
# Cada uno hace pull_next() sobre la misma cola de Munis.
OCR_WORKER_CONCURRENCY=1

# Segundos de espera entre polls cuando la cola está vacía.
OCR_POLL_INTERVAL_SECONDS=10

# Poner en "false" para deshabilitar el worker sin eliminar el contenedor.
OCR_WORKER_ENABLED=true

# Timeout HTTP (segundos) para callbacks a Munis (mark_processing, complete, fail).
OCR_CALLBACK_TIMEOUT_SECONDS=30

# Timeout HTTP (segundos) para la descarga del PDF fuente desde Munis.
OCR_DOWNLOAD_TIMEOUT_SECONDS=120

# El worker se detiene con exit(1) si acumula este número de errores consecutivos
# en pull_next (errores de red, 5xx, etc.).
OCR_WORKER_MAX_CONSECUTIVE_ERRORS=20

# Nivel de log del worker: DEBUG | INFO | WARNING | ERROR
OCR_WORKER_LOG_LEVEL=INFO


# ───────────────────────────────────────────────────────────────────────────────
# OCR PIPELINE — Configuración del motor OCR
# (válidas tanto para ocr-api como para ocr-worker)
# ───────────────────────────────────────────────────────────────────────────────

OCR_TMP_DIR=/data/tmp
OCR_OUT_DIR=/data/out
OCR_LANG=spa
OCR_MODE=searchable_cpu

# Opciones de preprocesamiento (false por defecto)
OCR_DESKEW=false
OCR_CLEAN=false
OCR_REMOVE_VECTORS=false

# Máscara de sellos/firmas
OCR_MASK_STAMPS=false
OCR_MASK_SIGNATURES=false
OCR_MASK_GRAYSCALE=false
OCR_MASK_DILATE=4

# Detector YOLO de sellos
STAMP_MODEL_PATH=/data/models/stamp_detector_v2.pt
OCR_MASK_DETECTOR_CONF=0.25
OCR_MASK_DETECTOR_IMGSZ=1024

# Detector YOLO de bloques de texto (opcional).
# Si no se define, el pipeline busca automáticamente el último .pt en
# data/out/text_pages/models/. Si no hay ninguno, la detección de texto no se activa.
#OCR_TEXT_BLOCK_MODEL_PATH=/data/out/text_pages/models/<modelo>.pt
#OCR_TEXT_BLOCK_CONF=0.25
#OCR_TEXT_BLOCK_IMGSZ=960
#OCR_TEXT_BLOCK_DEVICE=auto

# Parámetros heurísticos de detección
OCR_STAMP_MIN_AREA=20000
OCR_STAMP_MAX_AREA=400000
OCR_STAMP_CIRCULARITY=0.5
OCR_SIGNATURE_REGION=0.35


# ───────────────────────────────────────────────────────────────────────────────
# ocr-api — Opciones adicionales de la API on-demand
# ───────────────────────────────────────────────────────────────────────────────

REVIEW_APP_VERSION=1.2
CLASSIFY_DIR=/data/classify
CLASSIFY_CONF_THRESHOLD=0.99
